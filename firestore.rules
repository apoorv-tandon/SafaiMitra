rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == 'super_admin';
    }

    function isOrgAdmin(tenantId) {
      return isAuthenticated() && getUserData().role == 'org_admin' && getUserData().tenantId == tenantId;
    }
    
    function isSupervisor(tenantId) {
      return isAuthenticated() && getUserData().role == 'supervisor' && getUserData().tenantId == tenantId;
    }

    function isCleaner(tenantId) {
      return isAuthenticated() && getUserData().role == 'cleaner' && getUserData().tenantId == tenantId;
    }

    function hasTenantAccess(tenantId) {
      return isSuperAdmin() || isOrgAdmin(tenantId) || isSupervisor(tenantId) || isCleaner(tenantId);
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && getUserData().tenantId == resource.data.tenantId) || request.auth.uid == userId;
      allow create, update: if isSuperAdmin() || isOrgAdmin(request.resource.data.tenantId);
      allow delete: if isSuperAdmin();
    }

    // Organizations Collection
    match /organizations/{orgId} {
      allow read: if isSuperAdmin() || isOrgAdmin(orgId) || isSupervisor(orgId) || isCleaner(orgId);
      allow write: if isSuperAdmin();
    }

    // Locations Collection
    match /locations/{locationId} {
      allow read: if true; // Public read allowed for feedback dropdowns
      allow write: if isSuperAdmin() || isOrgAdmin(request.resource.data.tenantId);
    }

    // Washrooms Collection
    match /washrooms/{washroomId} {
      allow read: if true; // Public can read to submit feedback via QR
      allow write: if isSuperAdmin() || isOrgAdmin(request.resource.data.tenantId);
    }

    // Cleaner Assignments
    match /cleaner_assignments/{assignmentId} {
      allow read: if hasTenantAccess(resource.data.tenantId);
      allow write: if isSuperAdmin() || isOrgAdmin(request.resource.data.tenantId) || isSupervisor(request.resource.data.tenantId);
    }

    // Cleaning Submissions
    match /cleaning_submissions/{submissionId} {
      allow read: if hasTenantAccess(resource.data.tenantId);
      // Cleaners can submit their own proofs
      allow create: if isCleaner(request.resource.data.tenantId) && request.resource.data.cleanerId == request.auth.uid;
      // Admins/Supervisors can verify and update status
      allow update: if isSuperAdmin() || isOrgAdmin(resource.data.tenantId) || isSupervisor(resource.data.tenantId);
      allow delete: if isSuperAdmin();
    }

    // Customer Feedback
    match /customer_feedback/{feedbackId} {
      allow read: if hasTenantAccess(resource.data.tenantId);
      allow create: if true; // Anyone (even anonymous) can create feedback
      allow update, delete: if isSuperAdmin() || isOrgAdmin(resource.data.tenantId);
    }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false; 
    }
  }
}
