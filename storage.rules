rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Cleaners can upload photos to their tenant's folder
    match /cleaning_proofs/{tenantId}/{allPaths=**} {
      // Anyone in the tenant can read
      allow read: if isAuthenticated();
      // Allow create if authenticated, size is < 5MB, and it's an image
      allow create: if isAuthenticated() 
                    && request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      // Only admin via function/console can delete (or update)
      allow update, delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false; // Default deny
    }
  }
}
